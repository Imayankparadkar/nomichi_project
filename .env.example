# ──────────────────────────────────────────────────────────────────────────────
# Nomichi Trip Desk — Environment Variables
#
# Copy this file to nomichi-next/.env.local for local development.
# Never commit .env.local to git.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Find these in your Supabase project → Settings → API

# For Next.js client-side/browser (must have NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_SUPABASE_URL=https://vwvcfcvbiytujkqxxpvy.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# For Next.js server-side / API route handlers
SUPABASE_URL=https://vwvcfcvbiytujkqxxpvy.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── AI (Groq API) ────────────────────────────────────────────────────────────
# Get from https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ─── Message Queue (Upstash Redis) ─────────────────────────────────────────────
# Get from https://upstash.com/ (Create Redis Database -> REST API section)
UPSTASH_REDIS_REST_URL=your_upstash_redis_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token_here
